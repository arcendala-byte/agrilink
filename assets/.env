# Firebase Configuration
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=agrilink.firebaseapp.com
FIREBASE_PROJECT_ID=agrilink
FIREBASE_STORAGE_BUCKET=agrilink.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_key
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey

# Weather API
OPENWEATHER_API_KEY=your_openweather_api_key

# AI API (OpenAI or Gemini)
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key

# Payment
RAVE_PUBLIC_KEY=your_rave_public_key
RAVE_SECRET_KEY=your_rave_secret_key

# App Configuration
APP_ENVIRONMENT=development
APP_VERSION=1.0.0
