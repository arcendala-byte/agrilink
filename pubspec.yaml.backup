name: agrilink
description: AgriLink - Digital Agricultural Marketplace
version: 1.0.0+1

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  
  # UI & Design
  google_fonts: ^6.2.1
  material_design_icons_flutter: ^7.0.7296
  shimmer: ^3.0.0
  lottie: ^3.0.0
  animations: ^2.0.8
  
  # State Management
  flutter_riverpod: ^2.4.9
  
  # Navigation
  go_router: ^13.0.0
  
  # Storage & Cache
  shared_preferences: ^2.2.2
  path_provider: ^2.1.1
  
  # Maps & Location
  google_maps_flutter: ^2.5.0
  geolocator: ^10.1.0
  geocoding: ^2.1.1
  
  # Images & Media
  image_picker: ^1.0.5
  cached_network_image: ^3.3.1
  
  # Charts & Analytics
  fl_chart: ^0.66.0
  
  # Utilities
  intl: ^0.18.0
  url_launcher: ^6.2.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.1

flutter:
  uses-material-design: true
  
  assets:
    - assets/animations/
    - assets/icons/
    - assets/images/
    - assets/fonts/
